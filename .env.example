# ========================================================================
# DATABASE :: NEON SERVERLESS POSTGRESQL
# ========================================================================
# URL de conexión a Neon (formato: postgres://user:pass@host.neon.tech/db)
NEON_DATABASE_URL=
DATABASE_URL=

# ========================================================================
# GITHUB :: AUTH & WEBHOOKS
# ========================================================================
# Token con acceso a repositorios (repo scope para privados)
GITHUB_SEED_TOKEN=
GITHUB_TOKEN=

# Secret del webhook GitHub (generado en GitHub Webhook settings)
# Formato: whsec_xxxxx
NUXT_GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=

# ========================================================================
# IA :: DEEPSEEK API
# ========================================================================
# API key de DeepSeek (compatible OpenAI SDK)
NUXT_DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY=

# ========================================================================
# CLOUDFLARE R2 :: ASSET STORAGE
# ========================================================================
# Account ID de Cloudflare (dashboard → sidebar derecho)
CF_ACCOUNT_ID=

# API Token creado en R2 → Manage R2 API Tokens (Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Nombre del bucket R2
R2_BUCKET_NAME=portfolio-bucket

# URL pública del bucket (custom domain configurado en R2 Settings)
NUXT_PUBLIC_ASSETS_URL=https://assets.samuhlo.dev

# ========================================================================
# CONFIGURATION
# ========================================================================
# Modo estricto: requiere mainImgUrl, imagesUrl y liveUrl
# Valores: "true" (default) o "false"
NUXT_STRICT_MODE=true
