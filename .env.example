# ========================================================================
# DATABASE :: NEON SERVERLESS POSTGRESQL
# ========================================================================
# URL de conexión a Neon (formato: postgres://user:pass@host.neon.tech/db)
NEON_DATABASE_URL=
DATABASE_URL=

# ========================================================================
# GITHUB :: AUTH & WEBHOOKS
# ========================================================================
# Token con acceso a repositorios (repo scope para privados)
GITHUB_SEED_TOKEN=
GITHUB_TOKEN=

# Secret del webhook GitHub (generado en GitHub Webhook settings)
# Formato: whsec_xxxxx
NUXT_GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=

# ========================================================================
# IA :: DEEPSEEK API
# ========================================================================
# API key de DeepSeek (compatible OpenAI SDK)
NUXT_DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY=

# ========================================================================
# CONFIGURATION
# ========================================================================
# Modo estricto: requiere mainImgUrl, imagesUrl y liveUrl
# Valores: "true" (default) o "false"
NUXT_STRICT_MODE=true
